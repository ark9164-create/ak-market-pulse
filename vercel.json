{
  "routes": [
    { "src": "/rss-proxy(.*)",      "dest": "/api/rss-proxy$1" },
    { "src": "/yahoo-api/(.*)",     "dest": "/api/yahoo-proxy?path=$1" },
    { "src": "/fred-api/(.*)",      "dest": "/api/fred-proxy?path=$1" },
    { "src": "/findata-api/(.*)",   "dest": "/api/findata-proxy?path=$1" }
  ]
}
